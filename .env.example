# ==========================================
# VALORIA - Configuration Template
# ==========================================
# Copy this file to .env and customize for your environment
# IMPORTANT: Never commit .env to git - it's in .gitignore for security
#
# ⚠️  For PRODUCTION:
#   1. Generate secure secrets: openssl rand -base64 32
#   2. Set ENVIRONMENT=production
#   3. Update all service URLs and credentials
#   4. Remove default/weak passwords
#   5. Configure HTTPS/TLS certificates
#   6. Enable security headers
#   7. Set up rate limiting and DDoS protection

# ═════════════════════════════════════════
# ENVIRONMENT & SECURITY (REQUIRED)
# ═════════════════════════════════════════
ENVIRONMENT=development
# Options: development, staging, production

# SECURITY: Generate with: openssl rand -base64 32
# MUST NOT be "dev_secret_change_in_prod" in production
JWT_SECRET=dev_secret_change_in_prod
JWT_EXPIRATION_HOURS=24

# ═════════════════════════════════════════
# DATABASE (REQUIRED FOR ALL SERVICES)
# ═════════════════════════════════════════
DATABASE_URL=postgresql://valoria:valoria_dev@localhost:5432/valoria

# For production use strong password:
# DATABASE_URL=postgresql://valoria:$(openssl rand -base64 24)@prod-db-host:5432/valoria

# ═════════════════════════════════════════
# SERVICES - API GATEWAY
# ═════════════════════════════════════════
PORT=8080
# or use legacy name:
API_GATEWAY_PORT=8080

# Services URLs (Docker network: http://service-name:port)
# Local development: http://localhost:PORT
USER_SERVICE_URL=http://localhost:8001
COTATION_SERVICE_URL=http://localhost:8002
SCRAPER_SERVICE_URL=http://localhost:8003
PRICING_SERVICE_URL=http://localhost:8004

# CORS configuration (comma-separated origins)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4000
# Production: only allow specific domains
# CORS_ALLOWED_ORIGINS=https://app.valoria.com,https://www.valoria.com

# ═════════════════════════════════════════
# SERVICES - INDIVIDUAL PORTS
# ═════════════════════════════════════════
USER_SERVICE_PORT=8001
COTATION_SERVICE_PORT=8002
SCRAPER_SERVICE_PORT=8003
PRICING_SERVICE_PORT=8004

# ═════════════════════════════════════════
# REDIS
# ═════════════════════════════════════════
REDIS_URL=redis://localhost:6379
# Production: use strong auth
# REDIS_URL=redis://user:password@prod-redis-host:6379

# ═════════════════════════════════════════
# RABBITMQ
# ═════════════════════════════════════════
RABBITMQ_URL=amqp://guest:guest@localhost:5672
# Production: use strong credentials
# RABBITMQ_URL=amqp://user:$(openssl rand -base64 24)@prod-rabbitmq-host:5672

# Legacy format:
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
RABBITMQ_VHOST=/

# ═════════════════════════════════════════
# POSTGRES (for docker-compose)
# ═════════════════════════════════════════
POSTGRES_USER=valoria
POSTGRES_PASSWORD=valoria_dev
POSTGRES_DB=valoria
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ═════════════════════════════════════════
# SCRAPER SERVICE - OPTIONS
# ═════════════════════════════════════════
SCRAPER_TIMEOUT_SECONDS=30
SCRAPER_MAX_RETRIES=3
SCRAPER_BROWSER_TIMEOUT=60000

# ═════════════════════════════════════════
# FRONTEND
# ═════════════════════════════════════════
FRONTEND_PORT=4000
VITE_API_URL=http://localhost:8080
VITE_ENV=development

# ═════════════════════════════════════════
# LOGGING & MONITORING
# ═════════════════════════════════════════
LOG_LEVEL=info
# Options: debug, info, warn, error
SENTRY_DSN=

# ═════════════════════════════════════════
# APPLICATION
# ═════════════════════════════════════════
APP_NAME=valoria
DEBUG=true
